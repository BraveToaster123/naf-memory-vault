# Copy to .env and adjust. Never commit real values.

# Tier 1 + audit SQLite store (gitignored)
MQM_DB_PATH=./data/qa-memory.db

# Policy + curated journeys
MQM_POLICY_PATH=./packages/policy/mqm-policy.yaml
MQM_JOURNEYS_DIR=./journeys

# Identity / RBAC (from SSO in production)
MQM_USER_ROLE=qa_engineer
MQM_USER_ID=local-user

# Run context
MQM_ENV=local
MQM_APP_ID=loan-origination-portal
MQM_LOAN_SCENARIO=synthetic-retail-01

# CI-only
CI_COMMIT_SHA=
MQM_BASE_URL=https://staging.pilot-mortgage.example
# Set to 1 to actually run the staging e2e suite
MQM_RUN_E2E=0
