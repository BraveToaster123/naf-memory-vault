# Copy to .env and adjust. Never commit real values.

# Tier 1 + audit SQLite store (gitignored)
MEMORY_VAULT_DB_PATH=./data/memory-vault.db

# Policy + curated journeys
MEMORY_VAULT_POLICY_PATH=./packages/policy/memory-vault-policy.yaml
MEMORY_VAULT_JOURNEYS_DIR=./journeys

# Identity / RBAC (from SSO in production)
MEMORY_VAULT_USER_ROLE=qa_engineer
MEMORY_VAULT_USER_ID=local-user

# Run context
MEMORY_VAULT_ENV=local
MEMORY_VAULT_APP_ID=loan-origination-portal
MEMORY_VAULT_LOAN_SCENARIO=synthetic-retail-01

# CI-only
CI_COMMIT_SHA=
MEMORY_VAULT_BASE_URL=https://staging.pilot-mortgage.example
# Set to 1 to actually run the staging e2e suite
MEMORY_VAULT_RUN_E2E=0
