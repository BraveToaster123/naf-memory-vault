{
  "mcpServers": {
    "memory-vault": {
      "command": "npx",
      "args": ["tsx", "packages/mcp-server/src/index.ts"],
      "env": {
        "MEMORY_VAULT_POLICY_PATH": "./packages/policy/memory-vault-policy.yaml",
        "MEMORY_VAULT_DB_PATH": "./data/memory-vault.db",
        "MEMORY_VAULT_JOURNEYS_DIR": "./journeys",
        "MEMORY_VAULT_ENV": "local",
        "MEMORY_VAULT_USER_ROLE": "qa_engineer",
        "MEMORY_VAULT_USER_ID": "local-user"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--isolated",
        "--browser=chromium"
      ]
    },
    "azure-devops-mcp": {
      "command": "npx",
      "args": ["-y", "@microsoft/azure-devops-mcp@latest"],
      "env": {
        "AZURE_DEVOPS_EXT_PAT": "${env:AZURE_DEVOPS_EXT_PAT}",
        "AZURE_DEVOPS_ORG_URL": "https://dev.azure.com/your-org"
      }
    }
  }
}
